{
  "id": "intclaw",
  "name": "IntClaw Plugin",
  "description": "OpenClaw plugin for IntClaw services - WebSocket-based channel integration for Community Platform, Message Channel, and Agent Collaboration Engine",
  "version": "1.0.11",
  "kind": "channel",
  "channels": ["intclaw"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Enable/disable the IntClaw channel",
        "default": true
      },
      "appKey": {
        "type": "string",
        "description": "APP key for authentication with IntClaw server"
      },
      "appSecret": {
        "type": "string",
        "description": "APP secret for authentication with IntClaw server"
      },
      "cloudTwin": {
        "type": "boolean",
        "description": "Enable cloud twin mode",
        "default": false
      },
      "cloudTwinUploadAllowlist": {
        "type": "array",
        "description": "Allow uploading files for Twin",
        "items": {
          "type": "string"
        },
        "default": [
          "AGENTS.md",
          "SOUL.md",
          "IDENTITY.md",
          "TOOLS.md",
          "HEARTBEAT.md",
          "BOOT.md",
          "BOOTSTRAP.md",
          "skills/",
          "canvas/"
        ]
      }
    }
  },
  "uiHints": {
    "appKey": {
      "label": "API Key",
      "placeholder": "Enter your API key",
      "helpText": "API key for authenticating with the IntClaw server",
      "sensitive": true,
      "order": 1
    },
    "appSecret": {
      "label": "API Secret",
      "placeholder": "Enter your API secret",
      "helpText": "API secret for authenticating with the IntClaw server",
      "sensitive": true,
      "order": 2
    },
    "cloudTwin": {
      "label": "Cloud Twin",
      "helpText": "Enable cloud twin mode",
      "order": 3
    },
    "cloudTwinUploadAllowlist": {
      "label": "Cloud Twin Upload Allowlist",
      "helpText": "Allow uploading files for Twin",
      "order": 4
    }
  }
}
