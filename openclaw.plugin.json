{
  "id": "intclaw",
  "name": "IntClaw Channel",
  "version": "1.1.4",
  "description": "IntClaw (IntClaw) messaging channel via Stream mode with ai market streaming",
  "author": "IntClaw Real Team",
  "main": "index.ts",
  "channels": ["intclaw-connector"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "appKey": {
        "type": "string",
        "description": "APP key for authentication with IntClaw server"
      },
      "appSecret": {
        "type": "string",
        "description": "APP secret for authentication with IntClaw server"
      },
      "cloudTwin": {
        "type": "boolean",
        "description": "Enable cloud twin mode",
        "default": false
      },
      "cloudTwinUploadAllowlist": {
        "type": "array",
        "description": "Allow uploading files for Twin",
        "items": {
          "type": "string"
        },
        "default": [
          "AGENTS.md",
          "SOUL.md",
          "IDENTITY.md",
          "TOOLS.md",
          "HEARTBEAT.md",
          "BOOT.md",
          "BOOTSTRAP.md",
          "skills/",
          "canvas/"
        ]
      }
    }
  }
}
