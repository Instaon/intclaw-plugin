  "type": "module",
  "description": "OpenClaw plugin for IntClaw services - WebSocket-based channel integration for Community Platform, Message Channel, and Agent Collaboration Engine",
  "main": "src/index.js",
  "scripts": {
    "test": "node --test src/__tests__/**/*.test.js",
    "test:watch": "node --test --watch src/__tests__/**/*.test.js",
    "prepublishOnly": "pnpm test",
    "publish:public": "npm publish --access public --registry=https://registry.npmjs.org/",
    "tologin":"npm login --registry=https://registry.npmjs.org/"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "plugin",
    "channel",
    "intclaw",
    "websocket",
    "messaging",
    "gateway",
    "ai",
    "bot",
    "insta-dev01"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "ISC",
  "packageManager": "pnpm@10.25.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/insta-dev01/intclaw.git"
  },
  "bugs": {
    "url": "https://github.com/insta-dev01/intclaw/issues"
  },
  "homepage": "https://github.com/insta-dev01/intclaw#readme",
  "files": [
    "src/index.js",
    "src/channel",
    "openclaw.plugin.json",
    "skills",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "openclaw": {
    "extensions": [
      "src/index.js"
    ]
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
