{
  "name": "@insta-dev01/insta-claw-connector",
  "version": "1.0.12",
  "description": "Instagram Claw Connector - A lightweight OpenClaw channel plugin for WebSocket-based bidirectional messaging",
  "main": "index.ts",
  "types": "index.ts",
  "type": "module",
  "files": [
    "index.ts",
    "config.ts",
    "account-config.ts",
    "connection.ts",
    "protocol.ts",
    "logger.ts",
    "types.ts",
    "channel.ts",
    "sdk-dispatcher.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "artifact-upload.ts"
  ],
  "scripts": {
    "dev": "echo 'Run: openclaw start'",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:property": "vitest run tests/property",
    "test:unit": "vitest run tests/unit",
    "type-check": "tsc --noEmit",
    "publish:public": "npm publish --access public --registry=https://registry.npmjs.org/",
    "tologin": "npm login --registry=https://registry.npmjs.org/"
  },
  "keywords": [
    "openclaw",
    "instagram",
    "websocket",
    "channel",
    "connector",
    "open-responses"
  ],
  "author": "Instagram Claw Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "openclaw": "^2026.4.24",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.1.9",
    "fast-check": "^3.15.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channels": [
      "insta-claw-connector"
    ],
    "installDependencies": true
  }
}
