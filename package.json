{
  "name": "@insta-dev01/intclaw",
  "version": "1.1.3",
  "description": "IntClaw (IntClaw) channel connector — Stream mode with AI Card streaming",
  "main": "index.ts",
  "types": "index.ts",
  "type": "module",
  "files": [
    "index.ts",
    "config.ts",
    "src/**/*",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "echo 'No build needed - jiti loads TS at runtime'",
    "lint": "echo 'Lint check skipped'",
    "lint:fix": "echo 'Lint fix skipped'",
    "test": "vitest run tests/gateway-methods.unit.test.ts",
    "test:unit": "vitest run tests/gateway-methods.unit.test.ts",
    "test:integration": "vitest run tests/gateway-methods.unit.test.ts",
    "test:all": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage --exclude tests/gateway-methods.test.ts",
    "type-check": "npx tsc --noEmit",
    "version:check": "echo 'Version check skipped'",
    "release:prepare": "echo 'Release prepare skipped'",
    "release:publish": "npm publish --access public",
    "release:verify": "npm view @intclaw-real-ai/intclaw-connector version",
    "clean": "rm -rf node_modules package-lock.json",
    "install:fresh": "npm run clean && npm install",
    "dev": "echo 'Run: openclaw start'",
    "validate": "npm run lint && npm run type-check && npm run version:check",
    "publish:public": "npm publish --access public --registry=https://registry.npmjs.org/",
    "tologin":"npm login --registry=https://registry.npmjs.org/"
  },
  "keywords": [
    "intclaw",
    "channel",
    "stream",
    "ai-card",
    "connector"
  ],
  "author": "IntClaw Real Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Instaon/intclaw-plugin.git"
  },
  "homepage": "https://github.com/Instaon/intclaw-plugin",
  "bugs": "https://github.com/Instaon/intclaw-plugin",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "axios": "^1.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.0",
    "mammoth": "^1.8.0",
    "openclaw": "^2026.3.0",
    "pako": "^2.1.0",
    "pdf-parse": "^1.1.1",
    "ws": "^8.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.1.9",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channels": [
      "intclaw-connector"
    ],
    "installDependencies": true
  }
}
